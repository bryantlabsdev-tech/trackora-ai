# Copy to `.env` in this folder and set your key. Never commit `.env`.
# Server-only — do not use a VITE_ prefix; the frontend never sees this value.

OPENAI_API_KEY=

# Optional:
# OPENAI_MODEL=gpt-4o-mini
# API_PORT=3001
# LISTEN_HOST=0.0.0.0
#   Use 0.0.0.0 so phones on your Wi‑Fi can reach the API when testing Capacitor (still no key in the app).

# Frontend (Vite) — safe to commit example; real value usually in .env.local for native dev
# VITE_API_BASE_URL=http://192.168.x.x:3001
#   Required for Capacitor iOS/Android: origin of this Express API (no trailing slash).
