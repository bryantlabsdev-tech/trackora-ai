# Copy to `.env` in this folder and set your key. Never commit `.env`.
# Server-only — do not use a VITE_ prefix; the frontend never sees this value.

OPENAI_API_KEY=

# Server — Stripe Checkout (subscription). No VITE_ prefix.
# STRIPE_SECRET_KEY=sk_live_... or sk_test_...
# STRIPE_WEBHOOK_SECRET=whsec_...
#   Signing secret from Stripe Dashboard → Webhooks → your endpoint.
# APP_URL=https://your-frontend.example.com
#   No trailing slash. Used for Checkout success_url / cancel_url (e.g. Vite dev: http://localhost:5173).
#
# Server — Supabase service role (webhook unlocks Pro on profiles). Never expose to the client.
# SUPABASE_URL=https://YOUR_PROJECT.supabase.co
# SUPABASE_SERVICE_ROLE_KEY=eyJ...

# Optional:
# OPENAI_MODEL=gpt-4o-mini
# PORT=3001
#   Render sets PORT automatically; for local runs, defaults to 3001 if unset. Server binds to 0.0.0.0.

# Frontend (Vite) — optional override only (no trailing slash).
# Default API base is https://trackora-ai.onrender.com (see src/lib/apiBase.ts).
# VITE_API_BASE_URL=http://127.0.0.1:3001
#   Use for local API / Vite dev without hitting production.

# Supabase (Vite) — required for sign-in; use Project URL + anon public key (Settings → API).
# VITE_SUPABASE_URL=https://YOUR_PROJECT.supabase.co
# VITE_SUPABASE_PUBLISHABLE_KEY=your_anon_key
#
# Run supabase/migrations/001_profiles.sql in the Supabase SQL Editor (profiles + RLS + usage RPC + optional auth trigger).
#
# Upgrade to Pro uses POST /create-checkout-session on the API (see server/index.mjs). Point the frontend at the API with VITE_API_BASE_URL when needed.
