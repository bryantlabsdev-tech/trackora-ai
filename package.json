{
  "name": "trackora-ai",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "concurrently -k -n vite,api -c blue,magenta \"vite\" \"node server/index.mjs\"",
    "build": "vite build",
    "preview": "vite preview",
    "start": "node server/index.mjs",
    "cap:sync": "npm run build && env LANG=en_US.UTF-8 LC_ALL=en_US.UTF-8 npx cap sync",
    "cap:open:android": "npx cap open android",
    "cap:open:ios": "npx cap open ios",
    "cap:android": "npm run cap:sync && npx cap open android",
    "cap:ios": "npm run cap:sync && npx cap open ios"
  },
  "dependencies": {
    "@capacitor/android": "^7.4.2",
    "@capacitor/core": "^7.4.2",
    "@capacitor/ios": "^7.4.2",
    "cors": "^2.8.5",
    "dotenv": "^16.4.7",
    "express": "^4.21.2",
    "openai": "^6.33.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  },
  "devDependencies": {
    "@capacitor/cli": "^7.4.2",
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/react": "^18.3.18",
    "@types/react-dom": "^18.3.5",
    "@vitejs/plugin-react": "^4.3.4",
    "concurrently": "^9.1.2",
    "typescript": "~5.7.2",
    "vite": "^6.0.7"
  }
}
